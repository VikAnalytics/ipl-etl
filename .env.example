# Copy this file to .env and fill in your values.
# Never commit .env to git.

# For local use: direct Postgres connection string
# Found in: Supabase Dashboard → Settings → Database → Direct connection
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# For GitHub Actions: use the SESSION POOLER URL instead of the direct connection.
# IPv6 from GitHub runners breaks the direct connection; the pooler is IPv4-only.
# Found in: Supabase Dashboard → Settings → Database → Session pooler
# DATABASE_URL=postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres
